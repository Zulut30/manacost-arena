{
  "name": "manacost-arena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port=3000 --host=0.0.0.0\" \"tsx --watch server/index.ts\"",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx --watch server/index.ts",
    "build": "vite build && node scripts/prerender.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "scrape": "tsx server/scraper.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cloudscraper": "^4.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "lucide-react": "^0.546.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^22.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "autoprefixer": "^10.4.21",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "description": "Hearthstone Arena statistics — tier list, class winrates, legendary groups"
}
